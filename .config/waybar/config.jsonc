{
  "layer": "top",
  "position": "top",
  "margin-left": 10,
  "margin-right": 10,
  "margin-top": 10,
  "margin-bottom": 0,
  "spacing": 4,
  "modules-left": [
    "custom/arch",
    "hyprland/window",
    "cava"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "network",
    "pulseaudio",
    "cpu",
    "memory",
    "temperature",
    "battery",
    "battery#bat2",
    "clock"
  ],
  "include": [
    "~/.config/waybar/modules.json"
  ]
}
