{
  "custom/arch": {
    "format": "у°Ј‡",
    "tooltip": true,
    "tooltip-format": "btw"
  },
  "hyprland/window": {
    "max-length": 45
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "persistent-workspaces": { "*": 5 },
